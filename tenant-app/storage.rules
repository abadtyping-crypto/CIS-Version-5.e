rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isTenantMember(tenantId) {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/tenants/$(tenantId)/users/$(request.auth.uid));
    }

    function canAccessTenantStorage(tenantId) {
      return tenantId == 'testTenants' || isTenantMember(tenantId);
    }

    match /tenants/{tenantId}/{allPaths=**} {
      allow read, write: if canAccessTenantStorage(tenantId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
